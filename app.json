{
  "expo": {
    "name": "Tarif AI",
    "slug": "tarif-ai",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./public/tarif.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./public/tarif.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "package": "com.tarifai.app",
      "adaptiveIcon": {
        "foregroundImage": "./public/tarif.png",
        "backgroundColor": "#ffffff"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "bundler": "metro",
      "output": "single",
      "favicon": "./public/tarif.png"
    },
    "extra": {
      "eas": {
        "projectId": "0c57dc85-0bcb-463f-b2f0-58dc0504f938"
      }
    }
  }
}
